{
  "id": "swarmbench-03-review-gates",
  "description": "Required Inspector gates must stay distinct and block downstream closeout until the chain passes.",
  "scheduler": {
    "lane_caps": {
      "runner": 1,
      "builder": 1,
      "inspector": 1
    },
    "retry_delay_s": 1,
    "max_retries_by_agent": {
      "runner": 0,
      "builder": 0,
      "inspector": 0
    }
  },
  "files": {
    "initial_dispatches": "dispatches.initial.json",
    "handoff_requests": {
      "sb03--inspector-spec": "handoff.inspector-spec.json",
      "sb03--inspector-quality": "handoff.inspector-quality.json",
      "sb03--inspector-final": "handoff.inspector-final.json"
    }
  },
  "durations_s": {
    "sb03--builder-package": 4,
    "sb03--inspector-spec": 2,
    "sb03--inspector-quality": 2,
    "sb03--inspector-final": 1,
    "sb03--runner-closeout": 1
  },
  "expectations": {
    "min_max_parallel": 1,
    "expected_wait_any_makespan_s": 10,
    "expected_wait_all_makespan_s": 10,
    "expected_dispatch_count": 5,
    "min_reuse_count_by_agent": {
      "inspector": 2
    },
    "expected_completed_slice_ids": [
      "sb03--builder-package",
      "sb03--inspector-spec",
      "sb03--inspector-quality",
      "sb03--inspector-final",
      "sb03--runner-closeout"
    ],
    "must_start_after_done": [
      [
        "sb03--inspector-spec",
        "sb03--builder-package"
      ],
      [
        "sb03--inspector-quality",
        "sb03--inspector-spec"
      ],
      [
        "sb03--inspector-final",
        "sb03--inspector-quality"
      ],
      [
        "sb03--runner-closeout",
        "sb03--inspector-final"
      ]
    ]
  }
}
