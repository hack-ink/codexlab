{
  "id": "swarmbench-04-salvage",
  "description": "Builder salvage follow-ups may reuse the same work package only when ownership stays unchanged.",
  "scheduler": {
    "lane_caps": {
      "runner": 0,
      "builder": 1,
      "inspector": 0
    },
    "retry_delay_s": 1,
    "max_retries_by_agent": {
      "runner": 0,
      "builder": 0,
      "inspector": 0
    }
  },
  "files": {
    "initial_dispatches": "dispatches.initial.json",
    "handoff_requests": {
      "sb04--builder-partial": "handoff.builder-salvage.json"
    }
  },
  "durations_s": {
    "sb04--builder-partial": 3,
    "sb04--builder-salvage": 2
  },
  "terminal_status_by_slice": {
    "sb04--builder-partial": "partial"
  },
  "expectations": {
    "min_max_parallel": 1,
    "expected_wait_any_makespan_s": 5,
    "expected_wait_all_makespan_s": 5,
    "expected_dispatch_count": 2,
    "min_reuse_count_by_agent": {
      "builder": 1
    },
    "expected_completed_slice_ids": [
      "sb04--builder-partial",
      "sb04--builder-salvage"
    ],
    "expected_terminal_status_by_slice": {
      "sb04--builder-partial": "partial",
      "sb04--builder-salvage": "done"
    },
    "must_start_after_event": [
      [
        "sb04--builder-salvage",
        "sb04--builder-partial",
        "partial"
      ]
    ]
  }
}
