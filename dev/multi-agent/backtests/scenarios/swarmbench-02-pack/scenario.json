{
  "id": "swarmbench-02-pack",
  "description": "Pack short+follow-up into one work package to reduce dispatch overhead.",
  "scheduler": {
    "lane_caps": {
      "runner": 0,
      "builder": 2,
      "inspector": 0
    },
    "retry_delay_s": 1,
    "max_retries_by_agent": {
      "runner": 0,
      "builder": 0,
      "inspector": 0
    }
  },
  "dispatch_overhead_s": 15,
  "files": {
    "initial_dispatches": "dispatches.initial.json",
    "handoff_requests": {}
  },
  "durations_s": {
    "sb02--builder-long": 25,
    "sb02--builder-pack-short-plus-after": 25
  },
  "expectations": {
    "min_max_parallel": 2,
    "expected_wait_any_makespan_s": 40,
    "expected_wait_all_makespan_s": 40,
    "expected_dispatch_count": 2,
    "expected_completed_slice_ids": [
      "sb02--builder-long",
      "sb02--builder-pack-short-plus-after"
    ]
  }
}
